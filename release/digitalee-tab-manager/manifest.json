{
  "manifest_version": 3,
  "name": "Digitalee Tab Manager",
  "version": "0.2.0",
  "description": "A visual workspace for organizing, searching, and managing browser tabs with collections",
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_popup": "src/pages/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  }
}
